# peri Environment Configuration Template
# Copy to /etc/peri/env or ~/.peri_env and modify

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_BASE=https://api.openai.com/v1

# Provider selection (optional, auto = auto-detect)
# MODEL_PROVIDER=auto

# Log level
RUST_LOG=info

# Disable auto compact (optional, for low-memory systems)
# DISABLE_AUTO_COMPACT=true

# LD_LIBRARY_PATH (set automatically during deploy)
# export LD_LIBRARY_PATH=/opt/peri/lib:$LD_LIBRARY_PATH
